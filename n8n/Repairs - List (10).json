    {
      "parameters": {
        "jsCode": "const parent = $json;\n\n// Try multiple possible shapes\nconst subtasks =\n  (Array.isArray(parent.subtasks) && parent.subtasks) ||\n  (Array.isArray(parent.subtasks?.data) && parent.subtasks.data) ||\n  (Array.isArray(parent.tasks) && parent.tasks) ||\n  (Array.isArray(parent.tasks?.data) && parent.tasks.data) ||\n  [];\n\nif (subtasks.length === 0) {\n  return [{\n    json: {\n      parentId: parent.id,\n      parentName: parent.name,\n      message: \"No damages were reported, good job.\",\n      subtasks: []\n    }\n  }];\n}\n\nreturn subtasks.map(st => ({\n  json: {\n    parent: { id: parent.id, name: parent.name },\n    subtaskId: st.id,\n    subtaskName: st.name,\n    subtaskStatus: st.status?.status ?? st.status ?? null,\n    subtaskUrl: st.url ?? (st.id ? `https://app.clickup.com/t/${st.id}` : null),\n  }\n}));"
      },
