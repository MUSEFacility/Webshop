    {
      "parameters": {
        "jsCode": "const OWNER_COMMENT_FIELD_ID = \"8d333333-de44-4f45-b4d1-079540d99313\";\n\nfunction getOwnerComment(customFields) {\n  if (!Array.isArray(customFields)) return \"\";\n  const field = customFields.find(f => f.id === OWNER_COMMENT_FIELD_ID);\n  if (!field || field.value == null) return \"\";\n  return typeof field.value === \"string\"\n    ? field.value\n    : JSON.stringify(field.value);\n}\n\nconst all = $input.all().map(i => i.json);\n\n// If Split subtasks produced the \"no damages\" message (no subtaskId items)\nconst msgItem = all.find(x => typeof x.message === \"string\" && x.message.length);\nif (msgItem) {\n  return [{\n    json: {\n      parent: { id: msgItem.parentId, name: msgItem.parentName },\n      subtasks: [],\n      message: msgItem.message\n    }\n  }];\n}\n\n// Normal path: we received subtask detail objects\nconst parent = all[0]?.parent || null;\n\nconst subtasks = all.map(t => ({\n  id: t.id,\n  name: t.name,\n  status: t.status?.status || null,\n  url: t.url || null,\n\n  // creation time (raw + ISO)\n  dateCreatedRaw: t.date_created ?? null,\n  dateCreatedIso: t.date_created ? new Date(Number(t.date_created)).toISOString() : null,\n\n  description: (t.description || \"\").trim(),\n  ownerComment: getOwnerComment(t.custom_fields),\n  images: (t.attachments || [])\n    .filter(a => (a.mimetype || \"\").startsWith(\"image/\"))\n    .map(a => a.url)\n}));\n\nreturn [{ json: { parent, subtasks } }];"
      },
